{
  "expo": {
    "name": "Library",
    "slug": "library-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C1A0E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bbq.library"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2C1A0E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bbq.library"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
